# =============================================================================
# PetCare Software — Global Environment Variables
# =============================================================================
# Copy this file to .env and adjust values.
# Docker Compose reads .env automatically from the project root.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build
# =============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# MongoDB
# ═════════════════════════════════════════════════════════════════════════════

# Docker image version
MONGO_VERSION=7.0

# Host port mapping (change if 27017 conflicts with another service)
MONGO_PORT=27017

# Internal Docker hostname (service name in docker-compose)
MONGO_HOST=petcare-mongo

# Database name
MONGO_DATABASE=petcare

# MongoDB user credentials
MONGO_USERNAME=petcare_user
MONGO_PASSWORD=secure_password_change_me

# Connection URI (used by the backend to connect from within the Docker network)
# Format: mongodb://<user>:<password>@<host>:<port>/<database>?authSource=admin
MONGO_URI=mongodb://petcare_user:secure_password_change_me@petcare-mongo:27017/petcare?authSource=admin

# ═════════════════════════════════════════════════════════════════════════════
# Backend (Node.js / Express)
# ═════════════════════════════════════════════════════════════════════════════

# Host port mapping for the backend API
BACKEND_PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# JWT secret (must be at least 16 characters — change in production!)
JWT_SECRET=change_me_in_production_min_16_chars

# JWT token expiration duration
JWT_EXPIRES_IN=24h

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# Rate limiting — window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Rate limiting — max requests per window
RATE_LIMIT_MAX=100

# ═════════════════════════════════════════════════════════════════════════════
# Frontend (React / Vite)
# ═════════════════════════════════════════════════════════════════════════════

# Host port mapping for the frontend dev server
FRONTEND_PORT=5173

# Host port mapping for the frontend production preview
FRONTEND_PORT_PROD=8080

# API base URL (used by Vite at build time to set the runtime API endpoint)
# In development with the Vite proxy, this is only used for production builds.
VITE_API_URL=http://localhost:5000/api/v1

# ═════════════════════════════════════════════════════════════════════════════
# Mongo Express (optional — development only)
# ═════════════════════════════════════════════════════════════════════════════

# Uncomment to enable Mongo Express web UI for database administration
# ME_ENABLED=true
ME_PORT=8081